# ================= BACKEND =================
NODE_ENV=development
PORT=3000

MONGODB_SERVER_IP=mongodb://127.0.0.1:27017/fzone
# Atlas production example (include /fzone):
# mongodb+srv://fzoneworldproject_db_user:PASSWORD@cluster0.e2loh6w.mongodb.net/fzone?appName=Cluster0
REDIS_URL=redis://127.0.0.1:6379

ACCESS_SECRET=change-me-access-secret-min-32-chars
REFRESH_SECRET=change-me-refresh-secret-min-32-chars

# Admin signup disabled by default
ALLOW_ADMIN_SIGNUP=false

# Rate limiting (set RATE_LIMIT_ENABLED=false to disable in dev only)
RATE_LIMIT_ENABLED=true

# CORS — comma-separated origins (required in production)
# CORS_ORIGINS=https://app.example.com

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ================= FRONTEND (Vite) =================
VITE_API_BASE_URL=
VITE_API_PORT=3000
VITE_DEV_API_PROXY=http://127.0.0.1:3000
