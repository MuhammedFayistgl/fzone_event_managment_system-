# Copy these to Render → Environment (never commit real values)

NODE_ENV=production
PORT=10000

# MongoDB Atlas — use Connect → Drivers in Atlas dashboard
# Option A (Render/Linux): mongodb+srv://USER:PASS@cluster0.e2loh6w.mongodb.net/fzone?appName=Cluster0
# Option B (standard, all platforms):
MONGODB_SERVER_IP=mongodb://USER:PASS@ac-igsplqj-shard-00-00.e2loh6w.mongodb.net:27017,ac-igsplqj-shard-00-01.e2loh6w.mongodb.net:27017,ac-igsplqj-shard-00-02.e2loh6w.mongodb.net:27017/fzone?ssl=true&authSource=admin&replicaSet=atlas-14fpyp-shard-0

# Upstash Redis (optional — skip if not needed)
# REDIS_URL=rediss://default:YOUR_TOKEN@YOUR-ENDPOINT.upstash.io:6379

ACCESS_SECRET=generate-random-32-chars-minimum-here
REFRESH_SECRET=generate-different-32-chars-minimum

# Set after Vercel deploy — exact frontend URL(s), comma-separated
CORS_ORIGINS=https://your-app.vercel.app

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=placeholder-until-webhook-configured

REQUIRE_ADMIN_AUTH=true
ALLOW_ADMIN_SIGNUP=false
RATE_LIMIT_ENABLED=true

SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=change-me-strong-password
