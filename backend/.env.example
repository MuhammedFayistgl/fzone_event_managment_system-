# Server
PORT=8000

# MongoDB
MONGODB_SERVER_IP=mongodb://127.0.0.1:27017/fzone

# Redis
REDIS_URL=redis://127.0.0.1:6379

# JWT
ACCESS_SECRET=change-me-access-secret
REFRESH_SECRET=change-me-refresh-secret

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Security (Phase 1)
REQUIRE_ADMIN_AUTH=true
ALLOW_ADMIN_SIGNUP=false
RATE_LIMIT_ENABLED=true

# Bootstrap first admin (scripts/seedAdmin.js)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-strong-password

# CORS — comma-separated origins (dev also auto-allows http://192.168.x.x:*)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.73:5173,http://192.168.1.89:5173
